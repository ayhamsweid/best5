DATABASE_URL=postgresql://best5_app:replace-with-a-random-app-password@127.0.0.1:5432/besiktas
MIGRATION_DATABASE_URL=postgresql://best5_user:replace-with-a-different-migration-password@127.0.0.1:5432/besiktas
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-32-character-random-secret
JWT_ISSUER=best5-api
JWT_AUDIENCE=best5-admin
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
COOKIE_DOMAIN=
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY_HOPS=0
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX=120
MAX_UPLOAD_MB=5
ALLOWED_UPLOAD_MIME=image/png,image/jpeg,image/webp,image/gif
UPLOAD_DIR=uploads
ENABLE_DB_TOOLS=0
# Only set these temporarily when intentionally running `npm run seed`.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace-with-a-unique-strong-password
